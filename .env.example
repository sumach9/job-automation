# ── Job Search ────────────────────────────────────────────────────────────────
APIFY_TOKEN=
SERPAPI_KEY=

# ── LinkedIn Auto-Apply ───────────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Email Notifications ───────────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
NOTIFY_EMAIL=

# ── Apply Settings ────────────────────────────────────────────────────────────
MAX_BROWSER_OPENS=5
# "playwright" = headless (works on server) | "shell" = local Chrome only | "off" = never open
SIMPLIFY_MODE=playwright
SIMPLIFY_AUTO_SUBMIT=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3004
