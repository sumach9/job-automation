# ── Server ──────────────────────────────────────
PORT=3001

# ── Apify (job scraping) ─────────────────────────
# Get your token at https://console.apify.com/account/integrations
APIFY_TOKEN=

# ── Job search config ────────────────────────────
JOB_TITLES=Software Engineer,Frontend Developer,Full Stack Developer
JOB_LOCATIONS=Remote,New York,San Francisco
INTERVAL_MINUTES=5
MAX_APPS_PER_RUN=10

# ── Gmail notifications ──────────────────────────
# Use a Gmail App Password (not your main password)
# Enable at: https://myaccount.google.com/apppasswords
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password-here
NOTIFY_EMAIL=you@gmail.com
EMAIL_NOTIFICATIONS=false
